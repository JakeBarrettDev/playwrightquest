# Which runner to use. Options: local (default), docker
EXECUTION_RUNNER=local

# Base URL the Playwright runner uses to access fictitious sites.
# local runner default: http://localhost:3000
# docker runner default: http://host.docker.internal:3000 (macOS/Windows)
#                        http://localhost:3000 (Linux with --network host)
# production: set this to your deployed URL
PQ_BASE_URL=http://localhost:3000
